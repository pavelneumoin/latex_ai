# РабочийЛист.ai — пример переменных окружения
# Копировать в .env.local (не коммитится).

# ─── База данных ─────────────────────────────────────────────────────────────
# Для dev: SQLite-файл рядом с prisma/schema.prisma
DATABASE_URL="file:./dev.db"
# Для prod (Postgres): DATABASE_URL="postgresql://user:pass@host:5432/rabochiilist"

# ─── NextAuth ────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3010"
NEXTAUTH_SECRET="" # сгенерировать: openssl rand -base64 32

# ─── Email (magic-link) — оставить пусто для dev (письма пишутся в консоль) ─
EMAIL_SERVER_HOST=""
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="noreply@rabochiilist.ru"

# ─── LLM-провайдер ───────────────────────────────────────────────────────────
# mock | gigachat | claude | deepseek | openai | openrouter
LLM_PROVIDER="mock"
LLM_MODEL="" # имя модели у выбранного провайдера; пусто = default провайдера

# Anthropic (Claude)
ANTHROPIC_API_KEY=""

# GigaChat (Sber)
GIGACHAT_AUTH_KEY="" # base64(client_id:client_secret)
GIGACHAT_SCOPE="GIGACHAT_API_PERS"  # или GIGACHAT_API_B2B

# DeepSeek
DEEPSEEK_API_KEY=""

# OpenAI / OpenRouter
OPENAI_API_KEY=""
OPENROUTER_API_KEY=""

# ─── Файлы / хранилище ──────────────────────────────────────────────────────
STORAGE_DIR="./storage"          # относительно frontend/; меняется на /home/pavel/projects/rabochiilist/storage/ на проде

# ─── LaTeX ────────────────────────────────────────────────────────────────
# Команда для компиляции (xelatex / pdflatex / latexmk). На Windows MiKTeX.
LATEX_CMD="xelatex"

# ─── Платежи ────────────────────────────────────────────────────────────────
# mock | yookassa | qiwi | tinkoff
PAYMENTS_PROVIDER="mock"

# ЮKassa (рекомендуется как основной)
YOOKASSA_SHOP_ID=""
YOOKASSA_SECRET_KEY=""
YOOKASSA_RETURN_URL="http://localhost:3010/billing/success"

# QIWI (резерв)
QIWI_PUBLIC_KEY=""
QIWI_SECRET_KEY=""

# ─── Прочее ────────────────────────────────────────────────────────────────
NODE_ENV="development"
NEXT_PUBLIC_APP_NAME="РабочийЛист.ai"
